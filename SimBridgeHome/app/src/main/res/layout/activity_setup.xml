<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Setup"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- SIM Label -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="SIM LABEL (shown on Travel app)" android:textColor="#8B949E"
        android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
    <EditText
        android:id="@+id/etSimLabel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textColorHint="#4D5566"
        android:hint="e.g. Karachi SIM, Office SIM"
        android:textSize="14sp"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="20dp"
        android:inputType="text" />

    <!-- Server URL -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="SIGNALING SERVER URL" android:textColor="#8B949E"
        android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
    <EditText
        android:id="@+id/etServerUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textColorHint="#4D5566"
        android:hint="ws://your-server-ip:8080"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="20dp"
        android:inputType="textUri" />

    <!-- Pair Code -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="PAIR CODE (same on all devices)" android:textColor="#8B949E"
        android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="32dp">
        <EditText
            android:id="@+id/etPairCode"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:background="@drawable/input_bg"
            android:textColor="#00D4FF"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:inputType="number"
            android:layout_marginEnd="8dp" />
        <Button
            android:id="@+id/btnGenerateCode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Generate"
            android:textColor="#FFFFFF"
            android:backgroundTint="#21262D" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Save Settings"
        android:textColor="#0D1117"
        android:textStyle="bold"
        android:backgroundTint="#00D4FF" />

</LinearLayout>
