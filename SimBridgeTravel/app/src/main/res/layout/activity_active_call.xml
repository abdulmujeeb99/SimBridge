<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_menu_call"
        android:colorFilter="#3FB950"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvCallDirection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active Call"
        android:textColor="#8B949E"
        android:textSize="14sp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvCallNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+1 000 000 0000"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp"/>

    <!-- SIM Label -->
    <TextView
        android:id="@+id/tvSimLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Karachi SIM"
        android:textColor="#0D1117"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/badge_travel_bg"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvCallTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#00D4FF"
        android:textSize="22sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="40dp"/>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="20dp">
            <ImageButton android:id="@+id/btnMute"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:colorFilter="#8B949E"
                android:background="@drawable/card_bg" android:padding="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mute" android:textColor="#8B949E" android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="20dp">
            <ImageButton android:id="@+id/btnSpeaker"
                android:layout_width="56dp" android:layout_height="56dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:colorFilter="#8B949E"
                android:background="@drawable/card_bg" android:padding="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Speaker" android:textColor="#8B949E" android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnEnd"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:colorFilter="#FFFFFF"
        android:background="@drawable/circle_reject_bg"
        android:padding="16dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="End Call" android:textColor="#8B949E" android:textSize="12sp"
        android:layout_marginTop="8dp"/>

</LinearLayout>
