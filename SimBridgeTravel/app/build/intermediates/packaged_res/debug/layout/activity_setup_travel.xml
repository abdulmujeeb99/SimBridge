<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Setup"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter the same server URL and pair code shown in your Home app."
        android:textColor="#8B949E"
        android:textSize="13sp"
        android:layout_marginBottom="24dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="SIGNALING SERVER URL" android:textColor="#8B949E"
        android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etServerUrl"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textColorHint="#4D5566"
        android:hint="ws://your-server-ip:8080"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="20dp"
        android:inputType="textUri"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="PAIR CODE (from Home app)" android:textColor="#8B949E"
        android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etPairCode"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:textColor="#00D4FF"
        android:textSize="24sp"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:gravity="center"
        android:inputType="number"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Save &amp; Connect"
        android:textColor="#0D1117"
        android:textStyle="bold"
        android:backgroundTint="#00D4FF"/>

</LinearLayout>
